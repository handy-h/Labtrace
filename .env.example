# LabTrace 配置文件
# 复制此文件为 .env 并填入实际值

# 数据库加密密钥 (32字节 AES-256-GCM, 64位十六进制字符串)
# 生成方法: openssl rand -hex 32
DB_KEY=

# 阿里云 OCR 凭证
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=

# 服务端口
PORT=8080

# 数据库路径
DB_PATH=data/labtrace.db

# 上传文件目录
UPLOAD_DIR=data/uploads

# 备份文件目录
BACKUP_DIR=data/backups
