# LabTrace 配置文件
# 复制此文件为 .env 并填入实际值

# 数据库备份加密密钥 (AES-256-GCM)
# 用于加密/解密数据库备份文件 (.bak)，确保备份文件即使泄露也无法读取
# 要求: 32字节 = 256位，以十六进制字符串表示，共64个字符
#
# 生成方法:
#   openssl rand -hex 32
#
# 注意:
#   - 密钥丢失将无法恢复已加密的备份文件
#   - 更换密钥后，旧备份将无法解密
#   - 生产环境请使用 openssl rand -hex 32 生成随机密钥
#   - 请确保 .env 文件权限严格限制（Linux: chmod 600 .env；Windows: 右键属性 → 安全 → 移除其他用户权限）
DB_KEY=

# 阿里云 OCR 凭证
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=

# 服务端口
PORT=8080

# 数据库路径
DB_PATH=data/labtrace.db

# 上传文件目录
UPLOAD_DIR=data/uploads

# 备份文件目录
BACKUP_DIR=data/backups

# OCR 月度配额上限（每月允许的 API 调用次数）
OCR_QUOTA_MONTHLY=200

# CORS 允许的 Origin 白名单（逗号分隔，留空则仅允许同源请求）
# 示例: CORS_ORIGIN=http://localhost:3000,https://example.com
CORS_ORIGIN=

# Gin 运行模式（可选，debug/release）
# 默认由 Makefile / PowerShell 脚本自动设置，直接运行二进制文件时可手动指定
# GIN_MODE=debug
